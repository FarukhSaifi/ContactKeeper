{
  "name": "contactkeeper",
  "version": "1.0.0",
  "description": "Contact Keeper",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix client",
    "clientinstall": "npm install --prefix client",
    "build": "npm run build --prefix client",
    "install:all": "npm install && npm run clientinstall",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "keywords": [
    "contactkeeper",
    "contact management",
    "contact app",
    "contact manager",
    "contact management system",
    "contact management software",
    "contact management tool"
  ],
  "author": "Farukh <farook1x95@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "config": "^4.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  }
}
