{
  "info": {
    "name": "ContactKeeper API",
    "description": "REST API for ContactKeeper — user auth and contact management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5001",
      "description": "Override via ContactKeeper - Dev environment"
    },
    { "key": "token", "value": "" },
    { "key": "contact_id", "value": "" },
    { "key": "test_email", "value": "jane@example.com" },
    { "key": "test_password", "value": "password123" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Welcome",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/",
            "description": "Server health check — returns welcome message."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.environment.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/users",
            "description": "Create a new user account. Returns JWT token."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.environment.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/auth",
            "description": "Authenticate user. Returns JWT token."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/auth",
            "description": "Get authenticated user profile. Requires Bearer token."
          }
        }
      ]
    },
    {
      "name": "Contacts",
      "item": [
        {
          "name": "Get All Contacts",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/contacts",
            "description": "List all contacts for the authenticated user."
          }
        },
        {
          "name": "Create Contact",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json._id) pm.environment.set('contact_id', json._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Smith\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"5551234567\",\n  \"type\": \"personal\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/contacts",
            "description": "Create a new contact. Types: personal, work, family, friend."
          }
        },
        {
          "name": "Update Contact",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Smith Updated\",\n  \"phone\": \"5559876543\",\n  \"type\": \"work\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/contacts/{{contact_id}}",
            "description": "Update an existing contact by ID."
          }
        },
        {
          "name": "Delete Contact",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/contacts/{{contact_id}}",
            "description": "Delete a contact by ID."
          }
        }
      ]
    }
  ]
}
